# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit real secrets.

aws_region   = "ap-south-1"
environment  = "production"
project_name = "sentrygrid"

db_password = "CHANGE-ME-use-a-long-random-password"

# Generate both with: openssl rand -hex 32
jwt_access_secret  = "CHANGE-ME"
jwt_refresh_secret = "CHANGE-ME"

# Leave empty to run AI triage in mock mode
openai_api_key = ""

alert_notification_email = "you@example.com"

bastion_allowed_ssh_cidr = "203.0.113.4/32" # YOUR public IP, not 0.0.0.0/0
bastion_key_pair_name    = "your-existing-ec2-key-pair-name"

github_org_repo = "your-github-username/sentrygrid"
