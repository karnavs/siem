NODE_ENV=development
PORT=4000

# Postgres connection string (docker-compose provides this automatically)
DATABASE_URL=postgresql://sentrygrid:sentrygrid@localhost:5432/sentrygrid

# Generate strong random secrets for real deployments, e.g.: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000

# Optional — leave blank to run AI triage in mock mode
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# AWS (only used in deployed environments)
AWS_REGION=ap-south-1
SNS_ALERT_TOPIC_ARN=

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
